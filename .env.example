# PubMed / NCBI
PUBMED_BOT_NCBI_EMAIL=your.email@example.com
PUBMED_BOT_NCBI_API_KEY=

# EasyScholar (期刊等级查询, 通过期刊名查询)
# 获取密钥: 登录 easyscholar.cc -> 开放接口
# API: https://www.easyscholar.cc/open/getPublicationRank
PUBMED_BOT_EASYSCHOLAR_SECRET_KEY=

# LLM (OpenAI 兼容格式)
PUBMED_BOT_LLM_API_KEY=sk-xxx
PUBMED_BOT_LLM_BASE_URL=https://api.openai.com/v1
PUBMED_BOT_LLM_MODEL=gpt-4o
PUBMED_BOT_LLM_MAX_TOKENS=4096

# AI 摘要 Prompt (可自定义，修改后重启生效)
# 支持的输出字段: summary_en, summary_cn, innovation_points, limitations
# PUBMED_BOT_LLM_PROMPT_SUMMARIZE=你是一位生物医学研究助手。请分析以下论文并提供结构化评估。请以JSON格式回答...

# AI 全文深度分析 Prompt
# PUBMED_BOT_LLM_PROMPT_FULLTEXT=你是一位资深的生物医学研究分析师。请对以下论文全文进行深度分析...

# AI 对话系统 Prompt (支持变量: {title}, {journal}, {year}, {abstract_section}, {fulltext_section}, {summary_section})
# PUBMED_BOT_LLM_PROMPT_CHAT=你是一位专业的生物医学文献阅读助手...

# Unpaywall
PUBMED_BOT_UNPAYWALL_EMAIL=your.email@example.com

# Zotero
PUBMED_BOT_ZOTERO_LIBRARY_ID=
PUBMED_BOT_ZOTERO_LIBRARY_TYPE=user
PUBMED_BOT_ZOTERO_API_KEY=

# 数据库
PUBMED_BOT_DATABASE_URL=sqlite+aiosqlite:///./data/pubmed_bot.db
